<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Plantilla con estructura estándar Odoo: columnas fijas, barcode estándar -->
    <template id="report_lot_label_dymo">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="lot">
                <!-- Split lote/serie -->
                <t t-set="lot_split" t-value="lot.name.split('/')"/>
                <t t-set="lote" t-value="lot_split[0] if len(lot_split) > 0 else lot.name"/>
                <t t-set="serie" t-value="'/'.join(lot_split[1:]) if len(lot_split) > 1 else ''"/>

                <div class="page" style="margin: 0; padding: 0; width: 100%; height: 100%; page-break-after: always;">
                    <div class="o_report_simple_label_dymo" style="width: 100%; height: 100%; font-family: Arial, sans-serif;">
                        <table style="width: 100%; height: 100%; border-collapse: collapse; table-layout: fixed;">
                            <tr>
                                <!-- Columna izquierda: 50%, vertical top -->
                                <td style="width: 50%; vertical-align: top; padding: 2px;">
                                    <!-- Código small -->
                                    <small style="font-size:11px; width:100%; text-align:left; white-space:normal; word-break:normal; overflow-wrap:break-word; padding:1px; display: block;">
                                        <t t-esc="lot.product_id.default_code or ''"/>
                                    </small>
                                    <!-- Nombre y ubicación -->
                                    <div class="o_label_full" style="font-size: 10px; line-height: 1.1; padding: 2px; text-align: center;">
                                        <t t-esc="lot.product_id.name or ''"/>
                                        <t t-if="lot.product_id.x_ubicacion_temporal">
                                            <br/><span style="font-size: 8px; text-align: right; display: block;"> <t t-esc="lot.product_id.x_ubicacion_temporal"/> </span>
                                        </t>
                                    </div>
                                    <!-- Lote/Serie/Máquina -->
                                    <div style="font-size: 9px; padding: 1px; text-align: left;">
                                        <strong>Lote:</strong> <t t-esc="lote"/>
                                        <t t-if="serie and serie != lote"><br/><strong>Serie:</strong> <t t-esc="serie"/></t>
                                    </div>
                                    <t t-if="lot.x_machine_number">
                                        <div style="font-size: 8px; padding: 0 1px; text-align: left;">
                                            Máq: <t t-esc="lot.x_machine_number"/>
                                        </div>
                                    </t>
                                </td>
                                <!-- Columna derecha: 50%, vertical middle, barcode centrado -->
                                <td style="width: 50%; vertical-align: middle; padding: 2px; text-align: center;">
                                    <img t-att-src="'/report/barcode/?type=Code128&amp;value=' + (lot.product_id.barcode or lot.product_id.default_code or lot.name) + '&amp;width=100&amp;height=30'"
                                         style="max-height: 100%; max-width: 100%; display: block; margin: 0 auto;"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <!-- Paperformat -->
    <record id="paperformat_dymo_lot" model="report.paperformat">
        <field name="name">DYMO Lot Label</field>
        <field name="format">custom</field>
        <field name="page_width">57</field>
        <field name="page_height">32</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="orientation">Portrait</field>
        <field name="dpi">96</field>
    </record>

    <!-- Acción -->
    <record id="action_report_lot_label_dymo" model="ir.actions.report">
        <field name="name">Etiqueta DYMO por Lote</field>
        <field name="model">stock.lot</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_lot_labels.report_lot_label_dymo</field>
        <field name="print_report_name">'Etiqueta DYMO - %s' % (object.name)</field>
        <field name="paperformat_id" ref="custom_lot_labels.paperformat_dymo_lot"/>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_type">report</field>
    </record>
</odoo>